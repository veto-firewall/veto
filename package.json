{
  "name": "veto",
  "version": "3.0.1",
  "description": "Advanced filtering with GeoIP, ASN, domain, URL and content blocking capabilities. Simple Firewall for Privacy and Security",
  "main": "index.js",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit",
    "build": "webpack --mode production --config webpack.config.cjs",
    "package": "npm run build && cd dist && zip -r veto.zip * && cd ..",
    "package:win": "npm run build && cd dist && powershell Compress-Archive -Path * -DestinationPath veto.zip -Force && cd ..",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,html,css}\"",
    "check": "npm run lint && npm run format:check",
    "fix": "npm run lint:fix && npm run format",
    "web-ext:lint": "npm run build && web-ext lint --source-dir dist",
    "test": "TR_PATH=tests/reports/$(date --utc +%Y/%m/%d) && mkdir -p $TR_PATH && node --test-reporter-destination $TR_PATH/$(date --utc +%H%M%S).tap --test-reporter tap --test tests/e2e.mjs"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "ipaddr.js": "^2.3.0",
    "lru-cache": "^11.3.5",
    "mmdb-lib": "^3.0.2",
    "tar-stream": "^3.1.8"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/tar-stream": "^3.1.4",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "puppeteer": "^24.41.0",
    "rimraf": "^6.1.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "web-ext": "^10.1.0",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2"
  }
}
